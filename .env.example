# ==============================================================
# HyperCube appliance deploy — environment template
# Copy to `.env` next to docker-compose.yml and fill in the blanks.
# ==============================================================

# ---- Image version ----
# Track `latest` or pin to a specific commit (e.g. sha-abc1234).
IMAGE_TAG=latest

# ---- Port published on the host ----
HC_PORT=7003

# ---- Django ----
# Generate once and keep stable across deploys:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated. Use the exact hostnames/IPs the reverse proxy uses.
# Example: hypercube.example.com,192.168.0.16
DJANGO_ALLOWED_HOSTS=*

# Comma-separated origins. Leave blank to disable.
# Example: https://hypercube.example.com,http://192.168.0.16:7003
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_ALL_ORIGINS=false
CSRF_TRUSTED_ORIGINS=

# ---- PostgreSQL ----
DB_NAME=hypercube
DB_USER=hypercube
DB_PASSWORD=change-me-to-a-strong-password
